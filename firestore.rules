rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reference data — readable by any user (signed-in or guest), 
    // writable only by your import scripts (via the Admin SDK, which bypasses these rules).
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    match /sections/{sectionId} {
      allow read: if true;
      allow write: if false;
    }

    match /bulletinPages/{majorSlug} {
      allow read: if true;
      allow write: if false;
    }

    // User data — only the owning user can read/write their own docs.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /plans/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /schedules/{scheduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
// force redeploy
